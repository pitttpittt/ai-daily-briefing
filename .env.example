# --- Anthropic (obligatoire) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- Resend (recommandé : déliverabilité ~99%) ---
# Inscription sur https://resend.com — gratuit jusqu'à 3000 emails/mois
RESEND_API_KEY=re_xxx
# RESEND_FROM=onboarding@resend.dev   # défaut, sandbox
# RESEND_TO=you@example.com           # si vide, fallback sur SMTP_TO

# --- SMTP (alternative si tu n'utilises pas Resend) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
# Pour Gmail : créer un App Password sur https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
SMTP_TO=you@gmail.com

# --- Slack (optionnel, à venir) ---
SLACK_WEBHOOK_URL=
